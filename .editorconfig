root = true

[*]
indent_style = tab
tab_width = 4
end_of_line = lf
charset = utf-8
insert_final_newline = false
trim_trailing_whitespace = true

[logo.txt]
trim_trailing_whitespace = false

[{*.md,Cargo.lock}]
indent_style = space
tab_width = 2

[{*.json,*.json5,*.xml,*.nix}]
tab_width = 2

[*.rs]
insert_final_newline = true